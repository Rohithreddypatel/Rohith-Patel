<section
  class="gg-banner"
  id="gg-banner-{{ section.id }}"
  aria-label="{{ section.settings.heading | escape }}"
>

  {%- comment -%} ── TOP BAR ── {%- endcomment -%}
  <div class="gg-banner__topbar">

    <span class="gg-banner__brand">
      {{- section.settings.brand_name -}}
    </span>

    <span class="gg-banner__tagline">
      {{- section.settings.tagline -}}
    </span>

    <a
      class="gg-banner__choose-btn"
      href="{{ section.settings.choose_gift_url | default: '#' }}"
      aria-label="{{ section.settings.choose_gift_label | escape }}"
    >
      <span class="gg-btn__label">{{- section.settings.choose_gift_label -}}</span>
      <span class="gg-btn__arrow" aria-hidden="true">→</span>
    </a>

  </div>
  {%- comment -%} ── END TOP BAR ── {%- endcomment -%}


  {%- comment -%} ── HERO ── {%- endcomment -%}
  <div class="gg-banner__hero">

    {%- comment -%} Background sketch illustration {%- endcomment -%}
    {% if section.settings.background_image != blank %}
      <img
        class="gg-banner__bg"
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.background_image | image_url: width: 768  }} 768w,
          {{ section.settings.background_image | image_url: width: 1200 }} 1200w,
          {{ section.settings.background_image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt=""
        role="presentation"
        loading="eager"
        width="1920"
        height="800"
      >
    {% else %}
      {%- comment -%} Placeholder hatch pattern when no image is uploaded {%- endcomment -%}
      <div class="gg-banner__bg gg-banner__bg--placeholder" aria-hidden="true"></div>
    {% endif %}

    {%- comment -%} Overlay content (bottom-left) {%- endcomment -%}
    <div class="gg-banner__content">
      <h1 class="gg-banner__heading">{{- section.settings.heading -}}</h1>
      <p  class="gg-banner__description">{{- section.settings.description -}}</p>
      <a
        class="gg-banner__shop-btn"
        href="{{ section.settings.shop_now_url | default: '#' }}"
        aria-label="{{ section.settings.shop_now_label | escape }}"
      >
        <span class="gg-btn__label">{{- section.settings.shop_now_label -}}</span>
        <span class="gg-btn__arrow" aria-hidden="true">→</span>
      </a>
    </div>

  </div>
  {%- comment -%} ── END HERO ── {%- endcomment -%}


  {%- comment -%} ── TICKER ── {%- endcomment -%}
  <div class="gg-banner__ticker" aria-label="Marquee" aria-live="off">
    <div class="gg-banner__ticker-track" id="gg-ticker-{{ section.id }}">
      {%- comment -%}
        We render the text 8x here; JS will trim or clone further
        to guarantee seamless looping at any viewport width.
      {%- endcomment -%}
      {% for i in (1..8) %}
        <span class="gg-ticker__item">{{- section.settings.ticker_text -}}</span>
        <span class="gg-ticker__dot" aria-hidden="true"> ✦ </span>
      {% endfor %}
    </div>
  </div>
  {%- comment -%} ── END TICKER ── {%- endcomment -%}

</section>


{% stylesheet %}

/* ── CSS Custom Properties ── */
.gg-banner {
  --gg-topbar-bg     : #ffffff;
  --gg-topbar-border : #e0e0e0;
  --gg-brand-color   : #111111;
  --gg-tagline-color : #444444;
  --gg-cta-bg        : #f0e040;   /* yellow */
  --gg-cta-color     : #111111;
  --gg-shop-bg       : #111111;   /* black */
  --gg-shop-color    : #ffffff;
  --gg-ticker-bg     : #111111;
  --gg-ticker-color  : #ffffff;
  --gg-hero-min-h    : 520px;
  --gg-transition    : 0.28s cubic-bezier(0.4, 0, 0.2, 1);

  width: 100%;
  overflow: hidden;
  font-family: inherit;           /* respects Dawn's font stack */
  background: #f5f5f0;
}

/* ── Top Bar ── */
.gg-banner__topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 40px;
  background: var(--gg-topbar-bg);
  border-bottom: 1px solid var(--gg-topbar-border);
  position: relative;
  z-index: 10;
  gap: 16px;
}

.gg-banner__brand {
  font-size: 0.95rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gg-brand-color);
  white-space: nowrap;
  flex-shrink: 0;
}

.gg-banner__tagline {
  flex: 1;
  text-align: center;
  font-size: 0.82rem;
  color: var(--gg-tagline-color);
  letter-spacing: 0.02em;
  padding: 0 16px;
}

/* ── Choose Gift CTA (yellow) ── */
.gg-banner__choose-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 22px;
  background: var(--gg-cta-bg);
  color: var(--gg-cta-color);
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  border: 2px solid var(--gg-brand-color);
  white-space: nowrap;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
  transition: color var(--gg-transition);
}

/* Sliding fill animation (shared) */
.gg-banner__choose-btn::before,
.gg-banner__shop-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gg-brand-color);
  transform: translateX(-101%);
  transition: transform var(--gg-transition);
  z-index: 0;
}

.gg-banner__choose-btn:hover::before,
.gg-banner__shop-btn:hover::before {
  transform: translateX(0);
}

.gg-banner__choose-btn:hover {
  color: var(--gg-cta-bg);  /* yellow text on dark fill */
}

.gg-btn__label,
.gg-btn__arrow {
  position: relative;
  z-index: 1;
}

/* Arrow nudge on hover */
.gg-btn__arrow {
  display: inline-block;
  transition: transform 0.22s ease;
}
.gg-banner__choose-btn:hover .gg-btn__arrow,
.gg-banner__shop-btn:hover .gg-btn__arrow {
  transform: translateX(5px);
}

/* ── Hero Area ── */
.gg-banner__hero {
  position: relative;
  width: 100%;
  min-height: var(--gg-hero-min-h);
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.gg-banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

/* Fallback hatch pattern */
.gg-banner__bg--placeholder {
  background: repeating-linear-gradient(
    45deg,
    #e4e4de 0px,
    #e4e4de 1px,
    #f5f5f0 1px,
    #f5f5f0 20px
  );
}

/* Content block (bottom-left) */
.gg-banner__content {
  position: relative;
  z-index: 5;
  padding: 40px 48px 48px;
  max-width: 440px;
}

.gg-banner__heading {
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  font-weight: 900;
  line-height: 1.08;
  color: var(--gg-brand-color);
  margin: 0 0 14px;
  letter-spacing: -0.02em;
}

.gg-banner__description {
  font-size: 0.88rem;
  line-height: 1.65;
  color: #333;
  margin: 0 0 28px;
}

/* ── Shop Now CTA (black) ── */
.gg-banner__shop-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 28px;
  background: var(--gg-shop-bg);
  color: var(--gg-shop-color);
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  border: 2px solid var(--gg-shop-bg);
  position: relative;
  overflow: hidden;
  transition: color var(--gg-transition);
}

.gg-banner__shop-btn::before {
  background: #3a3a3a;  /* slightly lighter dark on hover */
}

.gg-banner__shop-btn:hover {
  color: var(--gg-shop-color);
}

/* ── Ticker ── */
.gg-banner__ticker {
  width: 100%;
  background: var(--gg-ticker-bg);
  color: var(--gg-ticker-color);
  padding: 10px 0;
  overflow: hidden;
  white-space: nowrap;
  user-select: none;
}

.gg-banner__ticker-track {
  display: inline-flex;
  align-items: center;
  /* JS sets the exact animation duration based on content width */
  will-change: transform;
}

.gg-ticker__item {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 0 28px;
}

.gg-ticker__dot {
  font-size: 0.6rem;
  opacity: 0.55;
}

/* Keyframe is added dynamically by JS for correct offset */
@keyframes gg-ticker-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(var(--gg-ticker-offset, -50%)); }
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .gg-banner__topbar {
    flex-direction: column;
    padding: 16px 20px;
    gap: 10px;
    text-align: center;
  }

  .gg-banner__tagline {
    padding: 0;
    font-size: 0.78rem;
  }

  .gg-banner__hero {
    min-height: 380px;
    align-items: center;
  }

  .gg-banner__content {
    padding: 28px 24px 36px;
    max-width: 100%;
  }

  .gg-banner__heading {
    font-size: 1.75rem;
  }
}

@media (max-width: 480px) {
  .gg-banner__heading {
    font-size: 1.5rem;
  }
}
{% endstylesheet %}


{% javascript %}

(function () {
  'use strict';

  function initTicker(trackId) {
    var track = document.getElementById(trackId);
    if (!track) return;

    
    function ensureTickerWidth() {
      var minWidth = window.innerWidth * 2.5;
      var safety   = 0;

      while (track.scrollWidth < minWidth && safety < 20) {
        var snapshot = Array.from(track.children);
        snapshot.forEach(function (child) {
          track.appendChild(child.cloneNode(true));
        });
        safety++;
      }

      var halfWidth = track.scrollWidth / 2;
      track.style.setProperty('--gg-ticker-offset', '-' + halfWidth + 'px');

      var duration = halfWidth / 80;
      track.style.animation =
        'gg-ticker-scroll ' + duration.toFixed(1) + 's linear infinite';
    }

    ensureTickerWidth();
    window.addEventListener('resize', ensureTickerWidth, { passive: true });
  }

  /* Kick off when DOM is ready */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      initTicker('gg-ticker-{{ section.id }}');
    });
  } else {
    initTicker('gg-ticker-{{ section.id }}');
  }

}());
{% endjavascript %}


{% schema %}
{
  "name": "Gift Guide Banner",
  "tag": "section",
  "class": "gift-guide-banner-wrapper",
  "settings": [
    {
      "type": "header",
