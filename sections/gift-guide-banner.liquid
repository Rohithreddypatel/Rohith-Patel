      "id": "tagline",
      "label": "Tagline (centre)",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "choose_gift_label",
      "label": "CTA Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "choose_gift_url",
      "label": "CTA Button Link"
    },
    {
      "type": "header",
      "content": "Hero / Banner"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (sketch illustration)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "shop_now_label",
      "label": "Shop Now Button Text",
      "default": "SHOP NOW"
